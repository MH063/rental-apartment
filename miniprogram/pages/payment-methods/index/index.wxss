.container { padding: 30rpx; }
.method-card { background: #fff; padding: 24rpx; border-radius: 28rpx; margin-bottom: 12rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.04); display: flex; align-items: center; }
.info { flex: 1; }
.type { font-size: 28rpx; font-weight: 500; display: block; }
.account { font-size: 24rpx; color: #999; }
.badge { background: #4f46e5; color: #fff; font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 8rpx; margin-right: 12rpx; }
.ops { display: flex; gap: 8rpx; }
.tag { background: #f0f0ff; color: #4f46e5; font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 12rpx; border: none; }
.tag.danger { background: #fef2f2; color: #ef4444; }
.form { background: #fff; padding: 24rpx; border-radius: 28rpx; margin-bottom: 16rpx; }
.input { background: #f5f5f5; padding: 20rpx; border-radius: 16rpx; font-size: 26rpx; margin-bottom: 12rpx; width: 100%; box-sizing: border-box; }
.btn-primary { background: linear-gradient(135deg, #4f46e5, #7c3aed); color: #fff; border: none; border-radius: 16rpx; padding: 20rpx; font-size: 28rpx; width: 100%; }
.btn-outline { background: none; border: 2rpx solid #4f46e5; color: #4f46e5; border-radius: 16rpx; padding: 20rpx; font-size: 28rpx; width: 100%; text-align: center; margin-top: 16rpx; }
.empty { text-align: center; padding: 40rpx; color: #ccc; font-size: 28rpx; }
