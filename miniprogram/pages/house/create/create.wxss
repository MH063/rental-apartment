.container {
  min-height: 100vh;
  padding: 0 30rpx 60rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #eef2ff 0%, #ffffff 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero {
  padding: 80rpx 0 48rpx;
  text-align: center;
}

.hero-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  line-height: 1.3;
}

.hero-desc {
  font-size: 26rpx;
  color: #94a3b8;
  margin-top: 12rpx;
  display: block;
}

.card {
  background: #fff;
  padding: 48rpx 40rpx 40rpx;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(15, 23, 42, 0.06);
  width: 100%;
  box-sizing: border-box;
}

.field {
  margin-bottom: 32rpx;
  transition: all 0.2s;
}

.label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
}

.required {
  color: #ef4444;
}

.counter {
  font-size: 24rpx;
  color: #94a3b8;
}

.input {
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  padding: 26rpx 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #0f172a;
  width: 100%;
  box-sizing: border-box;
  min-height: 88rpx;
  transition: border-color 0.2s;
}

.input:focus {
  border-color: #6366f1;
}

.input::placeholder {
  color: #cbd5e1;
  font-size: 28rpx;
}

.error {
  font-size: 22rpx;
  color: #ef4444;
  margin-top: 8rpx;
  display: block;
}

.field-error .input {
  border-color: #ef4444;
  background: #fef2f2;
}

.btn-primary {
  background: linear-gradient(135deg, #6366f1, #818cf8);
  color: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
  width: 100%;
  line-height: 1.4;
  margin-top: 16rpx;
  transition: opacity 0.2s;
}

.btn-primary::after {
  border: none;
}

.btn-disabled {
  opacity: 0.5;
}
