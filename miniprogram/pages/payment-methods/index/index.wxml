<wxs module="helper">
var iconOf = function(type) {
  if (type === '支付宝') return '💳'
  if (type === '微信') return '💚'
  if (type === '银行卡') return '🏦'
  return '💳'
}
var colorOf = function(type) {
  if (type === '支付宝') return 'alipay'
  if (type === '微信') return 'wechat'
  if (type === '银行卡') return 'bank'
  return ''
}
module.exports = { iconOf: iconOf, colorOf: colorOf }
</wxs>

<view class="page">
  <view class="header">
    <text class="header-title">支付方式</text>
    <text class="header-count" wx:if="{{methods.length}}">共 {{methods.length}} 个</text>
  </view>

  <view wx:if="{{loading && methods.length === 0}}" class="loading-wrap">
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:else>
    <view class="list">
      <view wx:for="{{methods}}" wx:key="id" class="method-card {{helper.colorOf(item.type)}}">
        <view class="card-left">
          <view class="card-icon-wrap {{helper.colorOf(item.type)}}">
            <text class="card-icon">{{helper.iconOf(item.type)}}</text>
          </view>
        </view>
        <view class="card-mid">
          <text class="card-type">{{item.type}}</text>
          <text class="card-account">{{item.account}}</text>
          <view class="card-qr-wrap" wx:if="{{item.qr_code}}" bindtap="onPreviewQr" data-url="{{item.qr_code}}">
            <image class="card-qr" src="{{item.qr_code}}" mode="aspectFill" />
            <text class="card-qr-tip">收款码</text>
          </view>
        </view>
        <view class="card-right">
          <view class="default-badge" wx:if="{{item.is_default}}">默认</view>
          <view class="card-ops">
            <text class="op-default" wx:if="{{!item.is_default}}" bindtap="onSetDefault" data-id="{{item.id}}">设为默认</text>
            <text class="op-delete" bindtap="onDelete" data-id="{{item.id}}">删除</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{methods.length === 0 && !loading}}" class="empty-wrap">
      <text class="empty-icon">💳</text>
      <text class="empty-title">暂无支付方式</text>
      <text class="empty-desc">添加后室友可以快捷向你转账</text>
    </view>
  </block>

  <!-- Modal -->
  <view wx:if="{{showModal}}" class="modal-mask" bindtap="onCloseModal">
    <view class="modal-box" catchtap="return">
      <view class="modal-header">
        <text class="modal-title">添加支付方式</text>
        <text class="modal-close" bindtap="onCloseModal">✕</text>
      </view>

      <view class="modal-body">
        <view class="field">
          <text class="field-label">支付类型</text>
          <picker class="field-picker" range="{{typeOptions}}" value="{{typeIndex}}" bindchange="onTypeChange">
            <view class="picker-value">{{typeOptions[typeIndex]}}</view>
          </picker>
        </view>

        <view class="field">
          <text class="field-label">收款账号</text>
          <input class="field-input" placeholder="请输入收款账号" value="{{account}}" bindinput="onAccountInput" maxlength="80" />
        </view>

        <view class="field">
          <text class="field-label">收款二维码</text>
          <view class="qr-upload" bindtap="onPickQr">
            <image wx:if="{{qrLocal}}" class="qr-preview" src="{{qrLocal}}" mode="aspectFill" />
            <view wx:else class="qr-placeholder">
              <text class="qr-icon">📷</text>
              <text wx:if="{{uploading}}" class="qr-text">上传中...</text>
              <text wx:else class="qr-text">点击上传收款码</text>
            </view>
          </view>
        </view>
      </view>

      <view class="modal-footer">
        <button class="btn-cancel" bindtap="onCloseModal">取消</button>
        <button class="btn-save" bindtap="onAdd">保存</button>
      </view>
    </view>
  </view>

  <view class="fab" bindtap="onOpenModal">
    <text class="fab-icon">+</text>
  </view>
</view>
