<view class="container">
  <view class="chart-card">
    <text class="card-title">月度趋势（近12月）</text>
    <view class="bar-chart">
      <view wx:for="{{trend}}" wx:key="month" class="bar-item">
        <view class="bar" style="height: {{(item.total / maxTrend) * 200 || 0}}rpx; background: linear-gradient(to top, #4f46e5, #8b5cf6);"></view>
        <text class="bar-label">{{item.month?.slice(5)}}</text>
      </view>
    </view>
  </view>
  <view class="chart-card">
    <text class="card-title">类目分布（近1月）</text>
    <view wx:for="{{category}}" wx:key="name" class="cat-item">
      <view class="cat-header">
        <text>{{item.name}}</text>
        <text class="cat-amount">{{(item.total / 100).toFixed(2)}} 元</text>
      </view>
      <view class="cat-bar-bg">
        <view class="cat-bar" style="width: {{(item.total / maxCat) * 100 || 0}}%;"></view>
      </view>
    </view>
  </view>
  <view class="chart-card" wx:if="{{yearly.length > 0}}">
    <text class="card-title">年度对比</text>
    <view wx:for="{{yearly}}" wx:key="month" class="year-item">
      <text class="year-month">第{{item.month}}月</text>
      <text class="year-this">今年: {{(item.this_year / 100).toFixed(0)}} 元</text>
      <text class="year-last">去年: {{(item.last_year / 100).toFixed(0)}} 元</text>
    </view>
  </view>
  <view wx:if="{{trend.length === 0 && category.length === 0}}" class="empty">暂无统计数据，请先录入账单</view>
</view>
