.page {
  min-height: 100vh;
  padding: 0 30rpx 60rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #eef2ff 0%, #ffffff 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero {
  padding: 72rpx 0 40rpx;
  text-align: center;
}

.hero-icon {
  font-size: 72rpx;
  display: block;
  margin-bottom: 16rpx;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  line-height: 1.3;
}

.hero-desc {
  font-size: 26rpx;
  color: #94a3b8;
  margin-top: 10rpx;
  display: block;
}

.card {
  background: #fff;
  padding: 0 0 40rpx;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(15, 23, 42, 0.06);
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

/* Sections */
.section {
  padding: 36rpx 40rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.section:last-of-type {
  border-bottom: none;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

/* Fields */
.field {
  margin-bottom: 28rpx;
  position: relative;
}

.field:last-child {
  margin-bottom: 0;
}

.field-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 0;
}

.field-row .field {
  margin-bottom: 0;
}

.half {
  flex: 1;
  min-width: 0;
}

.three {
  gap: 16rpx;
}

.third {
  flex: 1;
  min-width: 0;
}

.label {
  font-size: 26rpx;
  font-weight: 500;
  color: #475569;
  margin-bottom: 12rpx;
  display: block;
}

.required {
  color: #ef4444;
}

.counter {
  font-size: 22rpx;
  color: #94a3b8;
  position: absolute;
  right: 0;
  bottom: -4rpx;
}

.input {
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  padding: 24rpx 22rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: #0f172a;
  width: 100%;
  box-sizing: border-box;
  min-height: 76rpx;
  transition: border-color 0.2s;
}

.input:focus {
  border-color: #6366f1;
}

.input::placeholder {
  color: #cbd5e1;
  font-size: 26rpx;
}

/* Picker */
.picker {
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 14rpx;
  padding: 24rpx 22rpx;
  min-height: 76rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.picker-value {
  font-size: 28rpx;
  color: #0f172a;
}

.picker-value.placeholder {
  color: #cbd5e1;
}

/* Textarea */
.textarea {
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  padding: 24rpx 22rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: #0f172a;
  width: 100%;
  box-sizing: border-box;
  min-height: 140rpx;
  transition: border-color 0.2s;
}

.textarea:focus {
  border-color: #6366f1;
}

.textarea::placeholder {
  color: #cbd5e1;
  font-size: 26rpx;
}

/* Photo */
.photo-upload {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx dashed #d1d5db;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-preview {
  width: 100%;
  height: 100%;
}

.photo-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.photo-icon {
  font-size: 48rpx;
}

.photo-text {
  font-size: 22rpx;
  color: #9ca3af;
}

/* Button */
.btn-primary {
  background: linear-gradient(135deg, #6366f1, #818cf8);
  color: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
  width: calc(100% - 80rpx);
  line-height: 1.4;
  margin: 16rpx 40rpx 0;
  transition: opacity 0.2s;
}

.btn-primary::after {
  border: none;
}

.btn-disabled {
  opacity: 0.5;
}
