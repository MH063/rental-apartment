.container {
  min-height: 100vh;
  padding: 80rpx 40rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f8f7ff 0%, #ffffff 100%);
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
}

.card {
  background: #fff;
  width: 100%;
  padding: 56rpx 40rpx;
  border-radius: 28rpx;
  box-shadow: 0 24rpx 56rpx rgba(79, 70, 229, 0.14);
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
}

.desc {
  font-size: 26rpx;
  color: #9ca3af;
  margin-top: 16rpx;
  display: block;
}

.code-inputs {
  display: flex;
  justify-content: space-between;
  margin: 56rpx 0 48rpx;
  gap: 16rpx;
}

.code-cell {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  background: #f3f4f6;
  border-radius: 16rpx;
  font-size: 44rpx;
  font-weight: 600;
  color: #111827;
  text-align: center;
  caret-color: #4f46e5;
  transition: all 0.2s ease;
}

.code-cell.filled {
  background: #eef2ff;
  color: #4f46e5;
}

.code-cell:focus {
  background: #fff;
  box-shadow: 0 0 0 2rpx #4f46e5;
}

.btn-primary {
  background: linear-gradient(135deg, #4f46e5, #7c3aed);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 500;
  width: 100%;
  line-height: 1.4;
}

.btn-primary[disabled] {
  opacity: 0.5;
}

.btn-primary::after {
  border: none;
}
