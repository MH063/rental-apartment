.container { padding: 30rpx; }
.bill-card { background: #fff; padding: 28rpx; border-radius: 24rpx; margin-bottom: 16rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,.06); display: flex; align-items: center; justify-content: space-between; }
.card-hover { transform: scale(.98); opacity: .8; }
.bill-info { flex: 1; }
.bill-title { font-size: 30rpx; color: #333; font-weight: 500; display: block; }
.bill-date { font-size: 24rpx; color: #999; display: block; margin-top: 8rpx; }
.bill-right { display: flex; flex-direction: column; align-items: flex-end; gap: 8rpx; }
.bill-amount { font-weight: 700; color: #4f46e5; font-size: 32rpx; }
.bill-status { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 12rpx; }
.bill-status.pending { background: #fef3c7; color: #d97706; }
.bill-status.paid { background: #d1fae5; color: #059669; }
.bill-status.confirmed { background: #dbeafe; color: #2563eb; }
.bill-status.disputed { background: #fee2e2; color: #dc2626; }
.bill-status.re-confirmed { background: #e0e7ff; color: #4f46e5; }
.bill-status.cancelled { background: #f3f4f6; color: #9ca3af; }
.empty { text-align: center; padding: 80rpx 30rpx; }
.empty-text { color: #ccc; font-size: 28rpx; display: block; margin-bottom: 24rpx; }
.create-btn { background: linear-gradient(135deg, #4f46e5, #7c3aed); color: #fff; border: none; border-radius: 16rpx; padding: 20rpx 48rpx; font-size: 28rpx; display: inline-block; }
.empty-house { text-align: center; padding: 120rpx 30rpx; }
.empty-btn { display: inline-block; background: linear-gradient(135deg, #4f46e5, #7c3aed); color: #fff; border-radius: 16rpx; padding: 20rpx 48rpx; font-size: 28rpx; margin-top: 24rpx; }
