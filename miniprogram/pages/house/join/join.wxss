.page {
  min-height: 100vh;
  padding: 0 30rpx 60rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f0fdf4 0%, #ffffff 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero {
  padding: 80rpx 0 44rpx;
  text-align: center;
}

.hero-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  line-height: 1.3;
}

.hero-desc {
  font-size: 26rpx;
  color: #94a3b8;
  margin-top: 10rpx;
  display: block;
}

.card {
  background: #fff;
  padding: 48rpx 40rpx 36rpx;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(15, 23, 42, 0.06);
  width: 100%;
  box-sizing: border-box;
}

.code-inputs {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 36rpx;
}

.code-cell-wrap {
  width: 88rpx;
  height: 108rpx;
  border-bottom: 4rpx solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: border-color 0.2s;
}

.code-cell-wrap.filled {
  border-color: #22c55e;
}

.code-cell-wrap.focused {
  border-color: #16a34a;
}

.code-cell-wrap.shake {
  border-color: #ef4444;
  animation: shake 0.4s ease;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-10rpx); }
  40% { transform: translateX(10rpx); }
  60% { transform: translateX(-6rpx); }
  80% { transform: translateX(6rpx); }
}

.code-dot {
  font-size: 28rpx;
  color: #cbd5e1;
}

.code-digit {
  font-size: 48rpx;
  font-weight: 700;
  color: #0f172a;
}

.code-input {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
}

.error-text {
  font-size: 24rpx;
  color: #ef4444;
  text-align: center;
  display: block;
  margin-bottom: 20rpx;
  margin-top: -24rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
  width: 100%;
  line-height: 1.4;
  transition: opacity 0.2s;
}

.btn-primary::after {
  border: none;
}

.btn-primary.btn-disabled {
  opacity: 0.4;
}

.scan-link {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 28rpx;
  font-size: 26rpx;
  color: #64748b;
  padding: 12rpx;
}

.scan-icon {
  font-size: 28rpx;
}

.tip {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-top: 36rpx;
  padding: 20rpx 24rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.tip-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 1.5;
}
