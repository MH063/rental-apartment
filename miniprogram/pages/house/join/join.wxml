<view class="page">
  <view class="hero">
    <text class="hero-icon">🤝</text>
    <text class="hero-title">加入合租空间</text>
    <text class="hero-desc">输入室友分享给你的 6 位邀请码</text>
  </view>

  <view class="card">
    <view class="code-inputs">
      <view
        wx:for="{{6}}" wx:key="index"
        class="code-cell-wrap {{codeArr[index] ? 'filled' : ''}} {{focusIndex === index ? 'focused' : ''}} {{error ? 'shake' : ''}}"
      >
        <text class="code-dot" wx:if="{{!codeArr[index] && focusIndex !== index}}">•</text>
        <text class="code-digit" wx:elif="{{codeArr[index]}}">{{codeArr[index]}}</text>
        <input
          class="code-input"
          type="number"
          value="{{codeArr[index]}}"
          data-index="{{index}}"
          bindinput="onInput"
          bindtap="onTapCell"
          focus="{{focusIndex === index}}"
          disabled="{{loading}}"
        />
      </view>
    </view>

    <text class="error-text" wx:if="{{error}}">{{error}}</text>

    <button class="btn-primary {{!(code.length === 6 && !loading) ? 'btn-disabled' : ''}}" disabled="{{!(code.length === 6 && !loading)}}" bindtap="onLookup">
      <text wx:if="{{loading}}">验证中...</text>
      <text wx:else>加入房屋</text>
    </button>

    <view class="scan-link" bindtap="onScan">
      <text class="scan-icon">📷</text>
      <text>扫一扫二维码</text>
    </view>
  </view>

  <view class="tip">
    <text class="tip-icon">💡</text>
    <text class="tip-text">邀请码由房屋创建者在「邀请码」页面生成</text>
  </view>
</view>
