<wxs src="../../../utils/format.wxs" module="fmt" />
<wxs module="statusMap">
var textMap = {
  '草稿': '草稿',
  '已确认': '已确认',
  '争议中': '争议中',
  '再次确认': '再次确认',
  '待支付': '待支付',
  '已支付': '已支付'
}
var colorMap = {
  '草稿': 'draft',
  '已确认': 'confirmed',
  '争议中': 'disputed',
  '再次确认': 'reconfirmed',
  '待支付': 'pending',
  '已支付': 'paid'
}
module.exports = {
  getText: function(s) { return textMap[s] || s },
  getColor: function(s) { return colorMap[s] || '' }
}
</wxs>

<view class="page">
  <view wx:if="{{!hasHouse}}" class="empty-full">
    <text class="empty-icon">🏠</text>
    <text class="empty-title">你还没有加入房屋</text>
    <text class="empty-desc">加入房屋后才能查看你的账单</text>
    <navigator url="/pages/house/join/join" class="btn-primary">去加入房屋</navigator>
  </view>

  <block wx:else>
    <view class="header">
      <text class="header-title">我的账单</text>
      <text class="header-count" wx:if="{{bills.length}}">共 {{bills.length}} 笔</text>
    </view>

    <view wx:if="{{loading}}" class="loading-wrap">
      <text class="loading-text">加载中...</text>
    </view>

    <view wx:elif="{{error}}" class="error-wrap">
      <text class="error-text">{{error}}</text>
      <button class="btn-retry" bindtap="load">重新加载</button>
    </view>

    <view wx:elif="{{bills.length === 0}}" class="empty-full">
      <text class="empty-icon">📄</text>
      <text class="empty-title">暂无账单记录</text>
      <text class="empty-desc">你还没有参与任何账单</text>
      <button class="btn-primary" bindtap="onCreate">创建第一笔账单</button>
    </view>

    <view wx:else class="list">
      <view wx:for="{{bills}}" wx:key="id" class="bill-card" bindtap="onTap" data-id="{{item.id}}">
        <view class="bill-left">
          <view class="bill-cat">
            <text class="bill-cat-icon">📋</text>
          </view>
        </view>
        <view class="bill-mid">
          <text class="bill-title">{{item.title}}</text>
          <text class="bill-date">{{item.bill_date}}</text>
        </view>
        <view class="bill-right">
          <text class="bill-amount">{{fmt.money(item.total_amount)}}</text>
          <text class="bill-status {{statusMap.getColor(item.status)}}">{{statusMap.getText(item.status)}}</text>
        </view>
      </view>
    </view>
  </block>

  <view wx:if="{{hasHouse && bills.length > 0}}" class="fab" bindtap="onCreate">
    <text class="fab-icon">+</text>
  </view>
</view>
