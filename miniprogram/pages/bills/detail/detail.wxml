<view class="container">
  <view class="card" wx:if="{{bill}}">
    <text class="bill-title">{{bill.title}}</text>
    <text class="bill-amount">{{(bill.total_amount / 100).toFixed(2)}} 元</text>
    <view class="meta">
      <text>分类：{{bill.category_name || '未分类'}}</text>
      <text>日期：{{bill.bill_date}}</text>
      <text>状态：{{bill.status}}</text>
      <text>分摊方式：{{bill.split_type}}</text>
    </view>
    <button class="btn-primary" wx:if="{{bill.status === '草稿'}}" bindtap="onConfirm">确认账单</button>
  </view>
</view>
