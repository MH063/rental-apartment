.container { padding: 30rpx; }
.form { background: #fff; padding: 40rpx; border-radius: 28rpx; box-shadow: 0 24rpx 56rpx rgba(79,70,229,.22); }
.field { margin-bottom: 32rpx; }
.label { font-size: 28rpx; color: #666; margin-bottom: 12rpx; display: block; }
.input { background: #f5f5f5; padding: 24rpx; border-radius: 16rpx; font-size: 28rpx; width: 100%; box-sizing: border-box; }
.btn-primary { background: linear-gradient(135deg, #4f46e5, #7c3aed); color: #fff; border: none; border-radius: 16rpx; padding: 24rpx; font-size: 32rpx; margin-top: 20rpx; }
