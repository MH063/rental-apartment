.container { padding: 60rpx 30rpx; }
.card { background: #fff; padding: 40rpx; border-radius: 28rpx; box-shadow: 0 24rpx 56rpx rgba(79,70,229,.22); text-align: center; }
.title { font-size: 36rpx; font-weight: 700; display: block; }
.desc { font-size: 26rpx; color: #999; margin-top: 16rpx; display: block; }
.code-inputs { margin: 40rpx 0; }
.input { background: #f5f5f5; padding: 24rpx; border-radius: 16rpx; font-size: 40rpx; text-align: center; letter-spacing: 16rpx; width: 100%; box-sizing: border-box; }
.btn-primary { background: linear-gradient(135deg, #4f46e5, #7c3aed); color: #fff; border: none; border-radius: 16rpx; padding: 24rpx; font-size: 32rpx; width: 100%; }
.btn-primary[disabled] { opacity: .6; }
