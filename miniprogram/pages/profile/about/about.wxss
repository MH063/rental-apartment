.page {
  min-height: 100vh;
  padding: 0 30rpx 60rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f0fdf4 0%, #ffffff 100%);
}

.hero {
  padding: 60rpx 0 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo { font-size: 80rpx; margin-bottom: 16rpx; }

.app-name { font-size: 40rpx; font-weight: 700; color: #1e293b; }
.app-version { font-size: 26rpx; color: #94a3b8; margin-top: 6rpx; }

.card {
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(15,23,42,0.05);
  margin-bottom: 24rpx;
  overflow: hidden;
}

.card-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f8fafc;
}

.card-item:last-child { border-bottom: none; }

.card-label { font-size: 28rpx; color: #475569; font-weight: 500; }
.card-value { font-size: 28rpx; color: #1e293b; }

.desc-list { padding: 0 32rpx 20rpx; }

.desc-text { font-size: 26rpx; color: #64748b; display: block; line-height: 1.8; }

.footer-text { display: block; text-align: center; font-size: 24rpx; color: #cbd5e1; margin-top: 40rpx; }
