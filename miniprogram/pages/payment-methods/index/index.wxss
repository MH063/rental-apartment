.container {
  min-height: 100vh;
  padding: 30rpx;
  box-sizing: border-box;
  background: #f8f7ff;
}

.method-card {
  background: #fff;
  padding: 28rpx;
  border-radius: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: center;
}

.info {
  flex: 1;
  min-width: 0;
}

.type {
  font-size: 30rpx;
  font-weight: 500;
  color: #1f2937;
  display: block;
}

.account {
  font-size: 26rpx;
  color: #6b7280;
  margin-top: 8rpx;
  display: block;
  word-break: break-all;
}

.right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 16rpx;
}

.badge {
  background: #4f46e5;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

.ops {
  display: flex;
  gap: 8rpx;
}

.tag {
  background: #f0f0ff;
  color: #4f46e5;
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 12rpx;
  border: none;
  line-height: 1.4;
}

.tag::after {
  border: none;
}

.tag.danger {
  background: #fef2f2;
  color: #ef4444;
}

.form-card {
  background: #fff;
  padding: 40rpx;
  border-radius: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 24rpx 56rpx rgba(79, 70, 229, 0.14);
}

.form-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
  text-align: center;
  margin-bottom: 36rpx;
  display: block;
}

.field {
  margin-bottom: 28rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
  margin-bottom: 14rpx;
  display: block;
}

.required {
  color: #ef4444;
}

.input {
  background: #f3f4f6;
  padding: 26rpx 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #111827;
  width: 100%;
  box-sizing: border-box;
  min-height: 88rpx;
}

.input::placeholder {
  color: #9ca3af;
  font-size: 28rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #4f46e5, #7c3aed);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  padding: 26rpx;
  font-size: 32rpx;
  font-weight: 500;
  width: 100%;
  margin-top: 8rpx;
  line-height: 1.4;
}

.btn-primary::after {
  border: none;
}

.btn-outline {
  background: none;
  border: 2rpx solid #4f46e5;
  color: #4f46e5;
  border-radius: 16rpx;
  padding: 26rpx;
  font-size: 30rpx;
  width: 100%;
  text-align: center;
  margin-top: 16rpx;
  line-height: 1.4;
}

.btn-outline::after {
  border: none;
}

.empty {
  text-align: center;
  padding: 60rpx 40rpx;
  color: #9ca3af;
  font-size: 28rpx;
}
