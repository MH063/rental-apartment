.container { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 70vh; padding: 40rpx; }
.scan-area { text-align: center; }
.scan-icon { font-size: 96rpx; display: block; margin-bottom: 24rpx; }
.scan-tip { font-size: 32rpx; font-weight: 600; color: #333; display: block; }
.scan-desc { font-size: 26rpx; color: #999; margin-top: 16rpx; display: block; }
.manual-link { display: block; margin-top: 48rpx; color: #4f46e5; font-size: 28rpx; text-decoration: underline; }
