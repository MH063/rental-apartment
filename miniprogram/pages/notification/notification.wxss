.page {
  min-height: 100vh;
  padding: 0 30rpx 40rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fff7ed 0%, #ffffff 100%);
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 0 24rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

.header-badge {
  background: #ef4444;
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 18rpx;
  padding: 0 10rpx;
  display: block;
}

.btn-read {
  background: #f1f5f9;
  border: none;
  border-radius: 20rpx;
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  color: #64748b;
  font-weight: 500;
  line-height: 1.5;
}

.btn-read::after { border: none; }

.btn-read[disabled] { opacity: 0.4; }

/* Loading & Empty */
.loading-wrap, .empty-wrap {
  padding: 160rpx 0;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-text {
  font-size: 28rpx;
  color: #94a3b8;
}

.empty-icon { font-size: 80rpx; display: block; margin-bottom: 20rpx; }
.empty-title { font-size: 32rpx; font-weight: 600; color: #1e293b; display: block; }
.empty-desc { font-size: 26rpx; color: #94a3b8; display: block; margin-top: 10rpx; }

/* List */
.list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.notif-card {
  background: #fff;
  padding: 24rpx 24rpx 24rpx 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.04);
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  border-left: 6rpx solid transparent;
  transition: all 0.15s;
}

.notif-card:active {
  transform: scale(0.98);
}

.notif-card.unread {
  border-left-color: #f97316;
  background: linear-gradient(90deg, #fff7ed 0%, #ffffff 100%);
}

.notif-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  background: #f1f5f9;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.notif-icon {
  font-size: 30rpx;
}

.notif-body {
  flex: 1;
  min-width: 0;
}

.notif-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
  margin-bottom: 4rpx;
}

.notif-content {
  font-size: 26rpx;
  color: #64748b;
  display: block;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.notif-time {
  font-size: 22rpx;
  color: #cbd5e1;
  display: block;
  margin-top: 8rpx;
}

.notif-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #f97316;
  flex-shrink: 0;
  margin-top: 10rpx;
}
