.container { padding: 30rpx; }
.header-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.title { font-size: 32rpx; font-weight: 700; }
.read-btn { background: none; border: none; color: #4f46e5; font-size: 26rpx; padding: 0; }
.notif-card { background: #fff; padding: 24rpx; border-radius: 28rpx; margin-bottom: 12rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.04); }
.notif-text { font-size: 28rpx; display: block; }
.notif-time { font-size: 24rpx; color: #999; display: block; margin-top: 8rpx; }
.empty { text-align: center; padding: 80rpx; color: #ccc; font-size: 28rpx; }
