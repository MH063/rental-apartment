.container { padding: 30rpx; }
.header-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.title { font-size: 32rpx; font-weight: 700; }
.read-btn { background: linear-gradient(135deg, #4f46e5, #7c3aed); color: #fff; border: none; font-size: 26rpx; padding: 12rpx 32rpx; border-radius: 24rpx; line-height: 1.5; }
.read-btn[disabled] { opacity: .5; }
.notif-card { background: #fff; padding: 24rpx; border-radius: 28rpx; margin-bottom: 12rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.04); display: flex; align-items: flex-start; gap: 16rpx; }
.notif-card.unread { background: linear-gradient(135deg, #f5f3ff, #ede9fe); border-left: 6rpx solid #4f46e5; }
.notif-dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: #4f46e5; flex-shrink: 0; margin-top: 8rpx; }
.notif-body { flex: 1; }
.notif-text { font-size: 28rpx; display: block; }
.notif-time { font-size: 24rpx; color: #999; display: block; margin-top: 8rpx; }
.empty { text-align: center; padding: 80rpx; color: #ccc; font-size: 28rpx; }
