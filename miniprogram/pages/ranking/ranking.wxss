.container { padding: 30rpx; }
.filter-bar { display: flex; align-items: center; justify-content: center; gap: 16rpx; margin-bottom: 24rpx; background: #fff; padding: 20rpx; border-radius: 16rpx; }
.filter-bar text { font-size: 26rpx; color: #4f46e5; }
.sep { color: #ccc; }
.rank-item { background: #fff; padding: 20rpx 24rpx; border-radius: 28rpx; margin-bottom: 12rpx; display: flex; align-items: center; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.04); }
.rank-num { font-size: 32rpx; font-weight: 800; color: #4f46e5; width: 50rpx; }
.avatar { width: 64rpx; height: 64rpx; border-radius: 50%; margin: 0 16rpx; }
.name { font-size: 28rpx; flex: 1; }
.amount { font-size: 28rpx; font-weight: 600; color: #4f46e5; }
.empty { text-align: center; padding: 80rpx; color: #ccc; font-size: 28rpx; }
