<view class="container">
  <view class="section">
    <text class="section-title">当前房屋</text>
    <view wx:for="{{houses}}" wx:key="id" class="house-item" bindtap="onSwitchHouse" data-id="{{item.id}}" hover-class="item-hover">
      <text class="house-name">{{item.name}}</text>
      <text class="check" wx:if="{{item.id === currentHouseId}}">✓</text>
    </view>
  </view>
  <view class="section">
    <text class="section-title">预算设置</text>
    <view wx:for="{{categories}}" wx:key="id" class="budget-item">
      <text class="cat-name">{{item.name}}</text>
      <input class="budget-input" placeholder="月预算(元)" type="digit" value="{{budgetMap[item.id] || ''}}" bindinput="onBudgetInput" bindblur="onSetBudget" data-cat-id="{{item.id}}" />
    </view>
  </view>
</view>
