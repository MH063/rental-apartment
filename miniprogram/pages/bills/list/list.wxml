<view class="container">
  <view class="toolbar">
    <input placeholder="🔍 搜索账单" bindinput="onSearch" />
  </view>
  <scroll-view class="bill-list" bindscrolltolower="onScrollBottom">
    <view wx:for="{{bill.bills}}" wx:key="id" class="bill-card" bindtap="onBillTap" data-id="{{item.id}}">
      <view class="bill-left">
        <text class="bill-title">{{item.title}}</text>
        <text class="bill-date">{{item.bill_date}} · {{item.category_name || '未分类'}}</text>
      </view>
      <view class="bill-right">
        <text class="bill-amount">{{(item.total_amount / 100).toFixed(2)}}</text>
        <text class="bill-status {{item.status}}">{{item.status}}</text>
      </view>
    </view>
    <view wx:if="{{bill.bills.length === 0}}" class="empty">暂无账单</view>
  </scroll-view>
</view>
