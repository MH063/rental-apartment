.container { padding: 30rpx; }
.chart-card { background: #fff; border-radius: 28rpx; padding: 24rpx; margin-bottom: 24rpx; box-shadow: 0 24rpx 56rpx rgba(79,70,229,.22); }
.card-title { font-size: 32rpx; font-weight: 600; margin-bottom: 20rpx; display: block; }
.bar-chart { display: flex; align-items: flex-end; gap: 8rpx; height: 240rpx; padding-top: 20rpx; }
.bar-item { flex: 1; display: flex; flex-direction: column; align-items: center; height: 100%; justify-content: flex-end; }
.bar { width: 100%; border-radius: 8rpx 8rpx 0 0; min-height: 4rpx; }
.bar-label { font-size: 20rpx; color: #999; margin-top: 8rpx; }
.cat-item { margin-bottom: 16rpx; }
.cat-header { display: flex; justify-content: space-between; font-size: 26rpx; margin-bottom: 8rpx; }
.cat-amount { font-weight: 600; color: #4f46e5; }
.cat-bar-bg { background: #f0f0ff; height: 16rpx; border-radius: 8rpx; overflow: hidden; }
.cat-bar { height: 100%; background: linear-gradient(90deg, #4f46e5, #8b5cf6); border-radius: 8rpx; }
.year-item { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid #f5f5f5; font-size: 26rpx; }
.year-month { font-weight: 500; }
.year-this { color: #4f46e5; }
.year-last { color: #999; }
.empty { text-align: center; padding: 80rpx; color: #ccc; font-size: 28rpx; }
