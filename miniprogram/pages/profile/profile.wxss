.container { padding: 30rpx; }
.user-card { text-align: center; padding: 40rpx; }
.avatar { width: 120rpx; height: 120rpx; border-radius: 50%; }
.nickname { font-size: 32rpx; font-weight: 600; display: block; margin-top: 16rpx; }
.menu-section { background: #fff; border-radius: 28rpx; padding: 8rpx 0; margin-bottom: 24rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,.06); }
.section-title { font-size: 26rpx; color: #999; padding: 16rpx 24rpx; display: block; }
.house-item { display: flex; justify-content: space-between; padding: 20rpx 24rpx; font-size: 28rpx; border-bottom: 1rpx solid #f5f5f5; }
.check { color: #4f46e5; font-weight: 700; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 24rpx; font-size: 28rpx; border-bottom: 1rpx solid #f5f5f5; }
.arrow { color: #ccc; font-size: 32rpx; }
.logout { margin-top: 16rpx; color: #ef4444; background: none; border: 2rpx solid #ef4444; border-radius: 16rpx; padding: 20rpx; font-size: 28rpx; width: 100%; text-align: center; }
