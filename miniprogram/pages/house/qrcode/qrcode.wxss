.page {
  min-height: 100vh;
  padding: 0 30rpx 60rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f5f3ff 0%, #ffffff 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero {
  padding: 72rpx 0 40rpx;
  text-align: center;
}

.hero-icon {
  font-size: 72rpx;
  display: block;
  margin-bottom: 12rpx;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  line-height: 1.3;
}

.hero-desc {
  font-size: 26rpx;
  color: #94a3b8;
  margin-top: 8rpx;
  display: block;
}

.card {
  background: #fff;
  padding: 40rpx;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(15, 23, 42, 0.06);
  width: 100%;
  box-sizing: border-box;
  text-align: center;
}

/* Loading & Error */
.loading-wrap, .error-wrap {
  padding: 60rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #94a3b8;
}

.error-icon { font-size: 48rpx; }
.error-text { font-size: 26rpx; color: #ef4444; }

.btn-retry {
  margin-top: 16rpx;
  background: #f1f5f9;
  border: none;
  border-radius: 14rpx;
  padding: 16rpx 48rpx;
  font-size: 26rpx;
  color: #475569;
}

.btn-retry::after { border: none; }

/* QR */
.qr-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qr {
  width: 320rpx;
  height: 320rpx;
  display: block;
}

.qr-tip {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 12rpx;
  display: block;
}

.code-box {
  margin: 36rpx 0;
  text-align: center;
}

.code-label {
  font-size: 24rpx;
  color: #94a3b8;
  display: block;
  margin-bottom: 8rpx;
}

.code-value {
  font-size: 56rpx;
  font-weight: 800;
  color: #4f46e5;
  letter-spacing: 16rpx;
  display: block;
}

.code-expire {
  font-size: 22rpx;
  color: #cbd5e1;
  display: block;
  margin-top: 8rpx;
}

/* Actions */
.actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  width: 100%;
}

.btn-primary {
  flex: 1;
  background: linear-gradient(135deg, #6366f1, #818cf8);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.4;
}

.btn-primary::after { border: none; }

.btn-outline {
  flex: 1;
  background: none;
  border: 2rpx solid #6366f1;
  color: #6366f1;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.4;
}

.btn-outline::after { border: none; }

.share-tip {
  margin-top: 28rpx;
  font-size: 24rpx;
  color: #cbd5e1;
}

/* Extra info */
.extra-info {
  width: 100%;
  box-sizing: border-box;
  margin-top: 24rpx;
  padding: 28rpx 32rpx;
  background: #fafafa;
  border-radius: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.info-label {
  font-size: 24rpx;
  color: #94a3b8;
}

.info-value {
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
}

/* Share button */
.btn-share {
  width: 100%;
  box-sizing: border-box;
  margin-top: 32rpx;
  background: linear-gradient(135deg, #6366f1, #818cf8);
  color: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
}

.btn-share::after { border: none; }
