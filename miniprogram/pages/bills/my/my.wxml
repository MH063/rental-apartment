<wxs src="../../../utils/format.wxs" module="fmt" />
<wxs module="statusMap">
module.exports = {
  getText: function(status) {
    var map = {
      'pending': '待支付',
      'paid': '已支付',
      'confirmed': '已确认',
      'disputed': '争议中',
      're-confirmed': '再次确认',
      'cancelled': '已取消'
    }
    return map[status] || status
  },
  getColor: function(status) {
    var map = {
      'pending': 'pending',
      'paid': 'paid',
      'confirmed': 'confirmed',
      'disputed': 'disputed',
      're-confirmed': 're-confirmed',
      'cancelled': 'cancelled'
    }
    return map[status] || ''
  }
}
</wxs>
<view class="container">
  <view wx:if="{{!hasHouse}}" class="empty-house">
    <text class="empty-text">请先加入房屋</text>
    <navigator url="/pages/house/join/join" class="empty-btn">去加入</navigator>
  </view>
  <block wx:else>
    <view wx:for="{{bills}}" wx:key="id" class="bill-card" bindtap="onTap" data-id="{{item.id}}" hover-class="card-hover">
      <view class="bill-info">
        <text class="bill-title">{{item.title}}</text>
        <text class="bill-date">{{item.bill_date}}</text>
      </view>
      <view class="bill-right">
        <text class="bill-amount">{{fmt.money(item.total_amount)}} 元</text>
        <text class="bill-status {{statusMap.getColor(item.status)}}">{{statusMap.getText(item.status)}}</text>
      </view>
    </view>
    <view wx:if="{{bills.length === 0}}" class="empty">
      <text class="empty-text">暂无账单</text>
      <button class="create-btn" bindtap="onCreate">创建账单</button>
    </view>
  </block>
</view>
