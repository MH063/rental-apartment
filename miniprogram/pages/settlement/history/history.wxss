.container { padding: 30rpx; }
.settlement-card { background: #fff; padding: 24rpx; border-radius: 28rpx; margin-bottom: 16rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,.06); display: flex; align-items: center; }
.s-title { font-size: 28rpx; font-weight: 500; }
.s-status { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 8rpx; margin-left: 16rpx; background: #f5f5f5; }
.s-date { font-size: 24rpx; color: #999; margin-left: auto; }
.btn-primary { background: linear-gradient(135deg, #4f46e5, #7c3aed); color: #fff; border: none; border-radius: 16rpx; padding: 24rpx; font-size: 32rpx; width: 100%; margin-top: 16rpx; text-align: center; display: block; }
.empty { text-align: center; padding: 80rpx; color: #ccc; font-size: 28rpx; }
