.page {
  min-height: 100vh;
  padding: 0 30rpx 120rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
}

.header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 32rpx 0 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

.header-count {
  font-size: 24rpx;
  color: #94a3b8;
}

/* Loading & Error */
.loading-wrap, .error-wrap {
  padding: 100rpx 0;
  text-align: center;
}

.loading-text, .error-text {
  font-size: 28rpx;
  color: #94a3b8;
}

.btn-retry {
  margin-top: 20rpx;
  background: #f1f5f9;
  border: none;
  border-radius: 14rpx;
  padding: 16rpx 48rpx;
  font-size: 26rpx;
  color: #475569;
}

.btn-retry::after { border: none; }

/* Empty states */
.empty-full {
  padding: 160rpx 0;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
}

.empty-desc {
  font-size: 26rpx;
  color: #94a3b8;
  display: block;
  margin: 10rpx 0 32rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #6366f1, #818cf8);
  color: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 22rpx 56rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.4;
}

.btn-primary::after { border: none; }

/* Bill list */
.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bill-card {
  background: #fff;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.05);
  display: flex;
  align-items: center;
  gap: 20rpx;
  transition: transform 0.15s;
}

.bill-card:active {
  transform: scale(0.98);
}

.bill-left {
  flex-shrink: 0;
}

.bill-cat {
  width: 72rpx;
  height: 72rpx;
  background: #f1f5f9;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bill-cat-icon {
  font-size: 32rpx;
}

.bill-mid {
  flex: 1;
  min-width: 0;
}

.bill-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bill-date {
  font-size: 24rpx;
  color: #94a3b8;
  display: block;
  margin-top: 6rpx;
}

.bill-right {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.bill-amount {
  font-size: 34rpx;
  font-weight: 700;
  color: #4f46e5;
}

.bill-status {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  font-weight: 500;
}

.bill-status.draft { background: #f1f5f9; color: #64748b; }
.bill-status.pending { background: #fef3c7; color: #d97706; }
.bill-status.confirmed { background: #dbeafe; color: #2563eb; }
.bill-status.reconfirmed { background: #e0e7ff; color: #4f46e5; }
.bill-status.disputed { background: #fee2e2; color: #dc2626; }
.bill-status.paid { background: #d1fae5; color: #059669; }

/* FAB */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #6366f1, #818cf8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.4);
}

.fab-icon {
  font-size: 56rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}
