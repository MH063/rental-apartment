<view class="container">
  <view class="card">
    <text class="title">加入合租房屋</text>
    <text class="desc">输入寝室长分享的6位邀请码</text>

    <view class="code-inputs">
      <input
        wx:for="{{6}}"
        wx:key="index"
        class="code-cell {{codeArr[index] ? 'filled' : ''}}"
        type="number"
        maxlength="1"
        value="{{codeArr[index]}}"
        data-index="{{index}}"
        bindinput="onInput"
        bindtap="onTapCell"
        focus="{{focusIndex === index}}"
      />
    </view>

    <button class="btn-primary" bindtap="onLookup" disabled="{{loading || code.length !== 6}}">
      <text wx:if="{{loading}}">验证中...</text>
      <text wx:else>加入房屋</text>
    </button>
  </view>
</view>
