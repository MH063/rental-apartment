.container { padding: 30rpx; height: 100vh; display: flex; flex-direction: column; box-sizing: border-box; }
.toolbar { margin-bottom: 20rpx; }
.toolbar input { background: #f5f5f5; padding: 20rpx 28rpx; border-radius: 16rpx; font-size: 28rpx; }
.bill-list { flex: 1; overflow: auto; }
.bill-card { background: #fff; padding: 24rpx; border-radius: 28rpx; margin-bottom: 16rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,.06); display: flex; align-items: center; }
.bill-left { flex: 1; }
.bill-title { font-size: 28rpx; font-weight: 500; display: block; }
.bill-date { font-size: 24rpx; color: #999; margin-top: 4rpx; display: block; }
.bill-right { text-align: right; }
.bill-amount { font-size: 32rpx; font-weight: 700; color: #4f46e5; display: block; }
.bill-status { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; padding: 2rpx 12rpx; border-radius: 8rpx; background: #f5f5f5; }
.empty { text-align: center; padding: 80rpx; color: #ccc; font-size: 28rpx; }
