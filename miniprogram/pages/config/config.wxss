.page {
  min-height: 100vh;
  padding: 0 30rpx 60rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f1f5f9 0%, #ffffff 100%);
}

.header {
  padding: 32rpx 0 24rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

.loading-wrap {
  padding: 160rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #94a3b8;
}

/* Cards */
.card {
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.05);
  margin-bottom: 24rpx;
  overflow: hidden;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 28rpx 32rpx 0;
}

.card-icon {
  font-size: 30rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  flex: 1;
}

.card-hint {
  font-size: 22rpx;
  color: #94a3b8;
}

.card-body {
  padding: 16rpx 0;
}

/* List items */
.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f8fafc;
  transition: background 0.15s;
}

.list-item:active {
  background: #f8fafc;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-left {
  flex: 1;
  min-width: 0;
}

.list-item-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1e293b;
  display: block;
}

.list-item-addr {
  font-size: 24rpx;
  color: #94a3b8;
  display: block;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.list-item-right {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.check-mark {
  font-size: 28rpx;
  color: #22c55e;
  font-weight: 700;
}

.check-label {
  font-size: 24rpx;
  color: #22c55e;
  font-weight: 500;
}

/* Empty row */
.empty-row {
  padding: 40rpx;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #cbd5e1;
}

/* Budget rows */
.budget-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid #f8fafc;
}

.budget-row:last-child {
  border-bottom: none;
}

.cat-name {
  font-size: 28rpx;
  color: #475569;
  font-weight: 500;
}

.budget-input-wrap {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 14rpx;
  padding: 0 16rpx;
  min-height: 68rpx;
  width: 220rpx;
  transition: border-color 0.2s;
}

.budget-input-wrap:focus-within {
  border-color: #6366f1;
}

.budget-prefix {
  font-size: 26rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.budget-input {
  flex: 1;
  font-size: 28rpx;
  color: #0f172a;
  text-align: right;
  min-height: 64rpx;
  background: transparent;
  border: none;
}

.budget-input::placeholder {
  color: #cbd5e1;
  font-size: 26rpx;
}
