.page {
  min-height: 100vh;
  padding: 0 30rpx 120rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f0f9ff 0%, #ffffff 100%);
}

.header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 32rpx 0 24rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

.header-count {
  font-size: 24rpx;
  color: #94a3b8;
}

.loading-wrap {
  padding: 160rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #94a3b8;
}

/* List */
.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* Card */
.method-card {
  background: #fff;
  padding: 24rpx 24rpx 24rpx 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.05);
  display: flex;
  align-items: center;
  gap: 20rpx;
  border-left: 6rpx solid #e2e8f0;
  transition: border-color 0.2s;
}

.method-card.alipay { border-left-color: #1677ff; }
.method-card.wechat { border-left-color: #07c160; }
.method-card.bank { border-left-color: #fa8c16; }

.card-left { flex-shrink: 0; }

.card-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-icon-wrap.alipay { background: #e6f4ff; }
.card-icon-wrap.wechat { background: #e8f8ee; }
.card-icon-wrap.bank { background: #fff7e6; }

.card-icon { font-size: 34rpx; }

.card-mid {
  flex: 1;
  min-width: 0;
}

.card-type {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
}

.card-account {
  font-size: 26rpx;
  color: #64748b;
  display: block;
  margin-top: 4rpx;
  word-break: break-all;
}

.card-right {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.default-badge {
  background: #22c55e;
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
}

.card-ops {
  display: flex;
  gap: 12rpx;
}

.op-default, .op-delete {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
}

.op-default {
  background: #f0f0ff;
  color: #6366f1;
}

.op-delete {
  background: #fef2f2;
  color: #ef4444;
}

/* Empty */
.empty-wrap {
  padding: 140rpx 0;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon { font-size: 80rpx; display: block; margin-bottom: 20rpx; }
.empty-title { font-size: 32rpx; font-weight: 600; color: #1e293b; display: block; }
.empty-desc { font-size: 26rpx; color: #94a3b8; display: block; margin-top: 10rpx; }

/* Form */
.form-card {
  background: #fff;
  padding: 40rpx 36rpx;
  border-radius: 28rpx;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(15, 23, 42, 0.06);
}

.form-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  text-align: center;
  margin-bottom: 32rpx;
  display: block;
}

.form-field {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #475569;
  margin-bottom: 14rpx;
  display: block;
}

.required {
  color: #ef4444;
}

.form-picker {
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 14rpx;
  padding: 24rpx 22rpx;
  min-height: 76rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.picker-value {
  font-size: 30rpx;
  color: #0f172a;
}

.form-input {
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  padding: 24rpx 22rpx;
  border-radius: 14rpx;
  font-size: 30rpx;
  color: #0f172a;
  width: 100%;
  box-sizing: border-box;
  min-height: 76rpx;
}

.form-input:focus {
  border-color: #6366f1;
}

.form-input::placeholder {
  color: #cbd5e1;
  font-size: 28rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #6366f1, #818cf8);
  color: #fff;
  border: none;
  border-radius: 18rpx;
  padding: 26rpx;
  font-size: 30rpx;
  font-weight: 600;
  width: 100%;
  line-height: 1.4;
  margin-top: 8rpx;
}

.btn-primary::after { border: none; }

.btn-cancel {
  background: none;
  border: 2rpx solid #e2e8f0;
  color: #64748b;
  border-radius: 18rpx;
  padding: 24rpx;
  font-size: 28rpx;
  width: 100%;
  text-align: center;
  margin-top: 16rpx;
  line-height: 1.4;
}

.btn-cancel::after { border: none; }

/* FAB */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #6366f1, #818cf8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.4);
}

.fab-icon {
  font-size: 56rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}
