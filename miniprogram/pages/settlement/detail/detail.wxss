.container { padding: 30rpx; }
.card { background: linear-gradient(135deg, #4f46e5, #7c3aed); padding: 30rpx; border-radius: 28rpx; color: #fff; margin-bottom: 24rpx; }
.title { font-size: 32rpx; font-weight: 600; }
.status-badge { font-size: 24rpx; background: rgba(255,255,255,.2); padding: 4rpx 16rpx; border-radius: 8rpx; margin-left: 12rpx; }
.date { font-size: 24rpx; opacity: .8; display: block; margin-top: 8rpx; }
.items { margin-bottom: 24rpx; }
.item-card { background: #fff; padding: 24rpx; border-radius: 28rpx; margin-bottom: 12rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,.06); }
.item-header { display: flex; justify-content: space-between; align-items: center; }
.from { font-size: 28rpx; font-weight: 500; }
.item-amount { font-size: 36rpx; font-weight: 700; color: #4f46e5; }
.item-status { font-size: 24rpx; color: #999; margin-top: 8rpx; display: block; }
.item-actions { display: flex; gap: 12rpx; margin-top: 16rpx; }
.tag { background: #f0f0ff; color: #4f46e5; font-size: 24rpx; padding: 8rpx 24rpx; border-radius: 12rpx; border: none; }
.tag.danger { background: #fef2f2; color: #ef4444; }
.btn-primary { background: linear-gradient(135deg, #4f46e5, #7c3aed); color: #fff; border: none; border-radius: 16rpx; padding: 24rpx; font-size: 32rpx; width: 100%; }
