.container { padding: 30rpx; }
.header-card { background: linear-gradient(135deg, #4f46e5, #7c3aed); padding: 30rpx; border-radius: 28rpx; color: #fff; margin-bottom: 24rpx; display: flex; justify-content: space-between; align-items: center; }
.title { font-size: 32rpx; font-weight: 600; }
.link { font-size: 26rpx; color: rgba(255,255,255,.8); }
.member-card { background: #fff; padding: 24rpx; border-radius: 28rpx; margin-bottom: 16rpx; display: flex; align-items: center; box-shadow: 0 8rpx 24rpx rgba(0,0,0,.06); }
.avatar { width: 80rpx; height: 80rpx; border-radius: 50%; }
.info { margin-left: 20rpx; flex: 1; }
.name { font-size: 28rpx; font-weight: 500; display: block; }
.role { font-size: 24rpx; color: #999; }
.ops { display: flex; gap: 12rpx; }
.tag { background: #f0f0ff; color: #4f46e5; font-size: 24rpx; padding: 8rpx 20rpx; border-radius: 12rpx; border: none; }
.tag.danger { background: #fef2f2; color: #ef4444; }
