.container { padding: 30rpx; padding-bottom: 60rpx; }

/* 用户卡片 */
.user-card { display: flex; align-items: center; gap: 24rpx; background: linear-gradient(135deg, #4f46e5, #7c3aed, #8b5cf6); padding: 40rpx; border-radius: 28rpx; margin-bottom: 24rpx; box-shadow: 0 16rpx 40rpx rgba(79,70,229,.3); position: relative; }
.avatar { width: 100rpx; height: 100rpx; border-radius: 50%; border: 4rpx solid rgba(255,255,255,.3); }
.user-info { flex: 1; }
.nickname { font-size: 36rpx; font-weight: 700; color: #fff; display: block; }
.user-id { font-size: 22rpx; color: rgba(255,255,255,.7); display: block; margin-top: 6rpx; }
.edit-hint { position: absolute; right: 32rpx; top: 50%; transform: translateY(-50%); font-size: 22rpx; color: rgba(255,255,255,.6); }

/* 卡片区块 */
.card-section { background: #fff; border-radius: 28rpx; padding: 8rpx 0; margin-bottom: 24rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,.06); overflow: hidden; }
.section-title { font-size: 24rpx; color: #999; padding: 20rpx 28rpx 8rpx; display: block; }

/* 房屋列表项 */
.house-item { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 28rpx; border-bottom: 1rpx solid #f5f5f5; transition: all .2s; }
.house-item:last-child { border-bottom: none; }
.house-item.active { background: linear-gradient(90deg, #f5f3ff, transparent); }
.item-hover { background: #f9fafb; }
.house-info { flex: 1; }
.house-name { font-size: 30rpx; color: #333; font-weight: 500; display: block; }
.house-address { font-size: 24rpx; color: #999; display: block; margin-top: 6rpx; }
.house-badge { background: linear-gradient(135deg, #4f46e5, #7c3aed); color: #fff; font-size: 22rpx; padding: 6rpx 20rpx; border-radius: 20rpx; }

/* 菜单项 */
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 28rpx; border-bottom: 1rpx solid #f5f5f5; transition: all .2s; }
.menu-item:last-child { border-bottom: none; }
.menu-hover { background: #f9fafb; }
.menu-left { display: flex; align-items: center; gap: 20rpx; }
.menu-icon { width: 64rpx; height: 64rpx; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; flex-shrink: 0; }
.icon-create { background: #dbeafe; }
.icon-join { background: #d1fae5; }
.icon-qrcode { background: #e0e7ff; }
.icon-bill { background: #fef3c7; }
.icon-notif { background: #fce7f3; }
.icon-config { background: #f3f4f6; }
.icon-payment { background: #ede9fe; }
.icon-members { background: #fce7f3; }
.icon-about { background: #f0fdf4; }

.menu-text { font-size: 30rpx; color: #333; }
.arrow { color: #ccc; font-size: 36rpx; }

/* 退出按钮 */
.logout-btn { margin-top: 16rpx; color: #ef4444; background: #fff; border: 2rpx solid #ef4444; border-radius: 16rpx; padding: 24rpx; font-size: 30rpx; width: 100%; text-align: center; }
.logout-btn::after { border: none; }

/* Modal overlay */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(15, 23, 42, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-box {
  background: #fff;
  width: 620rpx;
  border-radius: 32rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 36rpx 0;
}

.modal-title { font-size: 34rpx; font-weight: 700; color: #1e293b; }
.modal-close { font-size: 36rpx; color: #94a3b8; padding: 10rpx; }

.modal-body { padding: 32rpx 36rpx; }

.field { margin-bottom: 28rpx; }
.field:last-child { margin-bottom: 0; }

.field-label { font-size: 28rpx; font-weight: 500; color: #475569; display: block; margin-bottom: 14rpx; }

.field-input {
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  padding: 24rpx 22rpx;
  border-radius: 14rpx;
  font-size: 30rpx;
  color: #0f172a;
  width: 100%;
  box-sizing: border-box;
  min-height: 76rpx;
}

.field-input:focus { border-color: #6366f1; }
.field-input::placeholder { color: #cbd5e1; font-size: 28rpx; }

/* Avatar upload */
.avatar-field { display: flex; align-items: center; gap: 24rpx; }
.avatar-field .field-label { margin-bottom: 0; }

.avatar-upload {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  position: relative;
  border: 2rpx solid #e2e8f0;
}

.avatar-preview { width: 100%; height: 100%; }

.avatar-overlay {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: rgba(0,0,0,0.5);
  padding: 6rpx 0;
  text-align: center;
}

.avatar-text { font-size: 20rpx; color: #fff; }

/* Modal footer */
.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 0 36rpx 36rpx;
}

.btn-cancel, .btn-save {
  flex: 1;
  border: none;
  border-radius: 18rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.4;
}

.btn-cancel {
  background: #f1f5f9;
  color: #64748b;
}

.btn-save {
  background: linear-gradient(135deg, #6366f1, #818cf8);
  color: #fff;
}

.btn-cancel::after, .btn-save::after { border: none; }
