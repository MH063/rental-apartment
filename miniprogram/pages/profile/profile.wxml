<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card" bindtap="onOpenEdit">
    <image class="avatar" src="{{(auth.user && auth.user.avatar) || '/assets/default-avatar.png'}}" />
    <view class="user-info">
      <text class="nickname">{{auth.user ? (auth.user.nickname || '用户') : '未登录'}}</text>
      <text class="user-id" wx:if="{{auth.user}}">ID: {{auth.user.id || auth.user.openid}}</text>
    </view>
    <text class="edit-hint">编辑 ›</text>
  </view>

  <!-- 加载失败 -->
  <view wx:if="{{loadError}}" class="error-wrap">
    <text class="error-text">加载失败，</text>
    <text class="error-retry" bindtap="onRetry">点击重试</text>
  </view>

  <!-- 当前房屋 -->
  <view class="card-section" wx:if="{{house.houses && house.houses.length > 0}}">
    <text class="section-title">当前房屋</text>
    <view wx:for="{{house.houses}}" wx:key="id" class="house-item {{item.id === house.currentHouseId ? 'active' : ''}}" hover-class="item-hover">
      <view class="house-info" bindtap="onSwitchHouse" data-id="{{item.id}}">
        <text class="house-name">{{item.name}}</text>
        <text class="house-address" wx:if="{{item.address}}">{{item.address}}</text>
      </view>
      <view class="house-right">
        <view class="house-badge" wx:if="{{item.id === house.currentHouseId}}">当前</view>
        <text class="house-more" bindtap="onHouseAction" data-id="{{item.id}}" data-name="{{item.name}}">···</text>
      </view>
    </view>
  </view>

  <!-- 房屋管理 -->
  <view class="card-section">
    <text class="section-title">房屋管理</text>
    <navigator url="/pages/house/create/create" class="menu-item" hover-class="menu-hover">
      <view class="menu-left">
        <view class="menu-icon icon-create">🏠</view>
        <text class="menu-text">创建房屋</text>
      </view>
      <text class="arrow">›</text>
    </navigator>
    <navigator url="/pages/house/join/join" class="menu-item" hover-class="menu-hover">
      <view class="menu-left">
        <view class="menu-icon icon-join">🔑</view>
        <text class="menu-text">加入房屋</text>
      </view>
      <text class="arrow">›</text>
    </navigator>
    <navigator url="/pages/house/qrcode/qrcode" class="menu-item" hover-class="menu-hover">
      <view class="menu-left">
        <view class="menu-icon icon-qrcode">📱</view>
        <text class="menu-text">房屋二维码</text>
      </view>
      <text class="arrow">›</text>
    </navigator>
    <navigator url="/pages/members/members" class="menu-item" hover-class="menu-hover">
      <view class="menu-left">
        <view class="menu-icon icon-members">👥</view>
        <text class="menu-text">成员管理</text>
      </view>
      <text class="arrow">›</text>
    </navigator>
  </view>

  <!-- 账单、结算与统计 -->
  <view class="card-section">
    <text class="section-title">账单、结算与统计</text>
    <navigator url="/pages/bills/my/my" class="menu-item" hover-class="menu-hover">
      <view class="menu-left">
        <view class="menu-icon icon-bill">📋</view>
        <text class="menu-text">我的账单</text>
      </view>
      <text class="arrow">›</text>
    </navigator>
    <navigator url="/pages/settlement/history/history" class="menu-item" hover-class="menu-hover">
      <view class="menu-left">
        <view class="menu-icon icon-settlement">📊</view>
        <text class="menu-text">结算记录</text>
      </view>
      <text class="arrow">›</text>
    </navigator>
    <navigator url="/pages/stats/stats" class="menu-item" hover-class="menu-hover">
      <view class="menu-left">
        <view class="menu-icon icon-stats">📈</view>
        <text class="menu-text">数据统计</text>
      </view>
      <text class="arrow">›</text>
    </navigator>
    <navigator url="/pages/ranking/ranking" class="menu-item" hover-class="menu-hover">
      <view class="menu-left">
        <view class="menu-icon icon-ranking">🏆</view>
        <text class="menu-text">成员排行</text>
      </view>
      <text class="arrow">›</text>
    </navigator>
    <navigator url="/pages/notification/notification" class="menu-item" hover-class="menu-hover">
      <view class="menu-left">
        <view class="menu-icon icon-notif">🔔</view>
        <text class="menu-text">通知中心</text>
      </view>
      <text class="arrow">›</text>
    </navigator>
  </view>

  <!-- 设置 -->
  <view class="card-section">
    <text class="section-title">设置</text>
    <navigator url="/pages/config/config" class="menu-item" hover-class="menu-hover">
      <view class="menu-left">
        <view class="menu-icon icon-config">⚙️</view>
        <text class="menu-text">预算与房屋设置</text>
      </view>
      <text class="arrow">›</text>
    </navigator>
    <navigator url="/pages/payment-methods/index/index" class="menu-item" hover-class="menu-hover">
      <view class="menu-left">
        <view class="menu-icon icon-payment">💳</view>
        <text class="menu-text">支付方式</text>
      </view>
      <text class="arrow">›</text>
    </navigator>
  </view>

  <!-- 关于 -->
  <view class="card-section">
    <text class="section-title">关于</text>
    <navigator url="/pages/profile/about/about" class="menu-item" hover-class="menu-hover">
      <view class="menu-left">
        <view class="menu-icon icon-about">ℹ️</view>
        <text class="menu-text">关于合租账单</text>
      </view>
      <text class="arrow">›</text>
    </navigator>
  </view>

  <button class="logout-btn" bindtap="onLogout">退出登录</button>
</view>

<!-- 编辑资料弹窗 -->
<view wx:if="{{showEdit}}" class="modal-mask" bindtap="onCloseEdit">
  <view class="modal-box" catchtap="return">
    <view class="modal-header">
      <text class="modal-title">编辑资料</text>
      <text class="modal-close" bindtap="onCloseEdit">✕</text>
    </view>

    <view class="modal-body">
      <view class="field avatar-field">
        <text class="field-label">头像</text>
        <view class="avatar-upload" bindtap="onPickAvatar">
          <image class="avatar-preview" src="{{editAvatarLocal || editAvatar || '/assets/default-avatar.png'}}" mode="aspectFill" />
          <view class="avatar-overlay">
            <text wx:if="{{uploading}}" class="avatar-text">上传中...</text>
            <text wx:else class="avatar-text">更换</text>
          </view>
        </view>
      </view>

      <view class="field">
        <text class="field-label">昵称</text>
        <input class="field-input" placeholder="请输入昵称" value="{{editNickname}}" bindinput="onNicknameInput" maxlength="20" />
      </view>
    </view>

    <view class="modal-footer">
      <button class="btn-cancel" bindtap="onCloseEdit">取消</button>
      <button class="btn-save" bindtap="onSaveProfile">保存</button>
    </view>
  </view>
</view>
